# Caddyfile para o OperaBeauty

{$DOMAIN:localhost} {
    tls cf95.souza@gmail.com {
        issuer acme {
            dir https://api.buypass.com/acme/directory
        }
    }

    # Compressão gzip/zstd para otimizar tráfego
    encode zstd gzip

    # Proxy reverso para o backend DEVE vir primeiro e isolado
    handle /api/* {
        reverse_proxy api:5000
    }

    # Todo o resto vai pro Frontend (React)
    handle {
        root * /srv/dist
        try_files {path} /index.html
        file_server
    }
}
