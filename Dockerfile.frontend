# Stage 1: Build do Frontend (React + Vite)
FROM node:20-alpine AS builder
WORKDIR /app

# Instala dependências
COPY package*.json ./
RUN npm ci

# Copia o restante do código e gera o build de produção
COPY . .
RUN npm run build

# Stage 2: Caddy Web Server
FROM caddy:2-alpine

# Copia os arquivos compilados do Stage 1 para a pasta que o Caddy serve
COPY --from=builder /app/dist /srv/dist

# Copia o arquivo de configuração do Caddy
COPY Caddyfile /etc/caddy/Caddyfile
